spring.application.name=Gateway-service

server.port=4000
# it allows to search the location of resources
# Enable Spring Cloud Gateway Discovery Locator
#spring.cloud.gateway.discovery.locator.enabled=true
#spring.cloud.gateway.discovery.locator.lower-case-service-id= true


# Routes configuration
spring.cloud.gateway.routes[0].id=ProductMS
spring.cloud.gateway.routes[0].uri=http://localhost:3334
spring.cloud.gateway.routes[0].predicates[0]=Path=/Ekart/product-api/**

#spring.cloud.gateway.routes[1].id=PaymentMS
#spring.cloud.gateway.routes[1].uri=http://localhost:3335
#spring.cloud.gateway.routes[1].predicates[0]=Path=/Ekart/payment-api/**

spring.cloud.gateway.routes[2].id=CartMS
spring.cloud.gateway.routes[2].uri=http://localhost:3335
spring.cloud.gateway.routes[2].predicates[0]=Path=/Ekart/customercart-api/**

spring.cloud.gateway.routes[3].id=CustomerMS
spring.cloud.gateway.routes[3].uri=http://localhost:3336
spring.cloud.gateway.routes[3].predicates[0]=Path=/Ekart/customer-api/customercarts/**
spring.cloud.gateway.routes[3].predicates[1]=Path=/Ekart/customerorder-api/**


logging.level.root=info
logging.level.org.springframework.cloud.gateway.route.RouteDefinitionLocation=INFO
logging.level.org.springframework.cloud.gateway = TRACE


#eureka.instance.hostname=localhost
#eureka.client.register-with-eureka=false
#eureka.client.fetch-registry=false
  
eureka.client.service-url.defaultZone= http://localhost:8761/eureka/
eureka.client.fetch-registry= true
eureka.client.register-with-eureka= true
            
         
      
